<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:dcterms="http://purl.org/dc/terms/"
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
   xmlns:skos="http://www.w3.org/2004/02/skos/core#"
>
  <rdf:Description rdf:about="https://clearhead.us/vocab/actions/v4#hasContextIdentifier">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="https://clearhead.us/vocab/actions/v4#Context"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment xml:lang="en">Maps the DSL tag name (e.g., "work", "computer") to the Context entity. Must be unique within workspace scope.</rdfs:comment>
    <rdfs:label xml:lang="en">has context identifier</rdfs:label>
    <skos:definition xml:lang="en">The string identifier used to reference this context in the DSL.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://clearhead.us/vocab/actions/v4#hasContextType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://clearhead.us/vocab/actions/v4#Context"/>
    <rdfs:range rdf:resource="https://clearhead.us/vocab/actions/v4#ContextType"/>
    <rdfs:comment xml:lang="en">Enables typed contexts for better organization and CCO alignment.</rdfs:comment>
    <rdfs:label xml:lang="en">has context type</rdfs:label>
    <skos:definition xml:lang="en">Relates a Context to its type classification.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://clearhead.us/vocab/actions/v4#Charter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000965"/>
    <rdfs:comment xml:lang="en">A Charter establishes the boundary of responsibility or interest without prescribing specific acts (that's Plan) or target states (that's Objective). It answers "what domain am I responsible for?"

Examples: "Health &amp; Fitness", "Career Development", "Home Maintenance"

Charters contain Plans (via has_part) and Plans serve Objectives (via inServiceOf). This creates the pipeline: Charter (scope) → Plan (prescription) → Planned Act (execution).

CCO has Plan and Objective but lacks a class for scope-of-concern declarations. Charter fills this genuine gap.</rdfs:comment>
    <rdfs:label xml:lang="en">Charter</rdfs:label>
    <skos:definition xml:lang="en">A Prescriptive Information Content Entity that declares the scope of directed concern for an agent or organization.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://clearhead.us/vocab/actions/v4#InProgress">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://www.commoncoreontologies.org/ont00000203"/>
    <rdfs:comment xml:lang="en">The Planned Act is currently being executed. File format: [-]</rdfs:comment>
    <rdfs:label xml:lang="en">In Progress</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/dc/terms/title">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://clearhead.us/vocab/actions/v4#hasDurationMinutes">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="https://www.commoncoreontologies.org/ont00000228"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <rdfs:comment xml:lang="en">Maps to the "D" syntax in the .actions file format (D60 = 60 minutes). Used for time blocking and capacity planning.</rdfs:comment>
    <rdfs:label xml:lang="en">has duration minutes</rdfs:label>
    <skos:definition xml:lang="en">Relates a Planned Act to its duration in minutes.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000051">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:comment xml:lang="en">In this vocabulary: Plan decomposition - parent actions have child actions as parts. Also Charter → Plan containment. Maps to the "&gt;" children syntax in the .actions file format.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00001767">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:comment xml:lang="en">In this vocabulary: Parent property for hasDoDateTime, hasCompletedDateTime, hasCreatedDateTime.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://clearhead.us/vocab/actions/v4#CategoryContextType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://clearhead.us/vocab/actions/v4#ContextType"/>
    <rdfs:comment xml:lang="en">General categories or domains. DSL syntax: +work, +personal, +urgent. For organization and filtering.</rdfs:comment>
    <rdfs:label xml:lang="en">Category Context Type</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00001868">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:comment xml:lang="en">In this vocabulary: Links a Planned Act to its Event Status Nominal ICE (lifecycle phase).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://clearhead.us/vocab/actions/v4#hasUUID">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="https://www.commoncoreontologies.org/ont00000974"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment xml:lang="en">Maps to the "#" syntax in the .actions file format. Provides universal uniqueness across systems and time. UUIDv7 encodes creation timestamp.</rdfs:comment>
    <rdfs:label xml:lang="en">has UUID</rdfs:label>
    <skos:definition xml:lang="en">Relates an entity in the action model to its unique identifier (UUIDv7 preferred).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://clearhead.us/vocab/actions/v4#requiresContext">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://www.commoncoreontologies.org/ont00000965"/>
    <rdfs:range rdf:resource="https://clearhead.us/vocab/actions/v4#Context"/>
    <rdfs:comment xml:lang="en">Maps to the "+" syntax in the .actions file format. Context entities enable tag hierarchies and typed contexts (facilities, agents, tools, etc.).</rdfs:comment>
    <rdfs:label xml:lang="en">requires context</rdfs:label>
    <skos:definition xml:lang="en">Relates a Plan to a Context entity required for execution.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://clearhead.us/vocab/actions/v4#inServiceOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://www.commoncoreontologies.org/ont00000965"/>
    <rdfs:range rdf:resource="https://www.commoncoreontologies.org/ont00000476"/>
    <rdfs:comment xml:lang="en">A teleological relation filling a genuine CCO gap: CCO has prescribes (plan→act) but lacks a relation for "this prescriptive entity serves that objective." Domain is Prescriptive ICE so both Plans and Charters can serve Objectives.

Maps to the "*" marker in the .actions file format. A Plan may serve zero objectives (standalone task) or multiple objectives.</rdfs:comment>
    <rdfs:label xml:lang="en">in service of</rdfs:label>
    <skos:definition xml:lang="en">Relates a Prescriptive Information Content Entity to the Objective it works toward.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000050">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:comment xml:lang="en">In this vocabulary: Plans are part_of Charters (scope containment).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://clearhead.us/vocab/actions/v4#Blocked">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://www.commoncoreontologies.org/ont00000203"/>
    <rdfs:comment xml:lang="en">The Planned Act cannot proceed due to an external dependency or blocker. File format: [=]</rdfs:comment>
    <rdfs:label xml:lang="en">Blocked</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://clearhead.us/vocab/actions/v4#AgentContextType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://clearhead.us/vocab/actions/v4#ContextType"/>
    <rdfs:comment xml:lang="en">People required for execution. DSL syntax: +@bob, +@manager. Maps to CCO Agent.</rdfs:comment>
    <rdfs:label xml:lang="en">Agent Context Type</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://clearhead.us/vocab/actions/v4#Context">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000965"/>
    <rdfs:comment xml:lang="en">Context represents execution requirements following Getting Things Done (GTD) methodology. Contexts support hierarchical relationships for tag organization and inheritance. Maps to "+" syntax in .actions file format.</rdfs:comment>
    <rdfs:label xml:lang="en">Context</rdfs:label>
    <skos:definition xml:lang="en">A resource, location, tool, or person required for plan execution (GTD context methodology).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://clearhead.us/vocab/actions/v4">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <owl:versionIRI rdf:resource="https://clearhead.us/vocab/actions/v4/4.2.0"/>
    <owl:imports rdf:resource="https://www.commoncoreontologies.org/InformationEntityOntology"/>
    <owl:imports rdf:resource="https://www.commoncoreontologies.org/AgentOntology"/>
    <owl:imports rdf:resource="https://www.commoncoreontologies.org/EventOntology"/>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-01-21</dcterms:created>
    <dcterms:creator>Darrion Burgess</dcterms:creator>
    <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-02-15</dcterms:modified>
    <dcterms:title>CCO Extension for Intention Information Entities</dcterms:title>
    <rdfs:comment xml:lang="en">A disciplined extension to the Common Core Ontologies (CCO) for modeling
intentional planning and execution.

This ontology fills genuine gaps in CCO's coverage of intention information entities:
- Charter: A Prescriptive ICE declaring scope of directed concern (CCO has Plan and Objective but no scope class)
- inServiceOf: A teleological relation linking Prescriptive ICEs to the Objectives they serve (CCO lacks this)

CCO modules imported (via owl:imports):
- InformationEntityOntology: Prescriptive ICE (ont00000965), Event Status Nominal ICE (ont00000203), prescribes (ont00001942), is_measured_by_nominal (ont00001868)
- AgentOntology: Plan (ont00000974), Objective (ont00000476)
- EventOntology: Planned Act (ont00000228), Act (ont00000832)

Transitively available via CCO import chain:
- ExtendedRelationOntology: is_successor_of (ont00001775)
- TimeOntology, GeospatialOntology, BFO 2020

InformationEntityOntology is imported directly (not just transitively) because Prescriptive ICE
(ont00000965) is the foundational parent class for Charter, Context, Plan, and Objective —
all core vocabulary classes. Making this dependency explicit ensures Protégé resolves it
correctly without relying on transitive catalog lookups.

Local resolution: see catalog-v001.xml for IRI → local file mappings.
For full CCO definitions, see: https://github.com/CommonCoreOntology/CommonCoreOntologies
For design rationale, see: V4_DESIGN.md</rdfs:comment>
    <rdfs:label>CCO Extension for Intention Information Entities</rdfs:label>
    <owl:versionInfo>4.2.0</owl:versionInfo>
  </rdf:Description>
  <rdf:Description rdf:about="https://clearhead.us/vocab/actions/v4#contextNarrower">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://clearhead.us/vocab/actions/v4#Context"/>
    <rdfs:range rdf:resource="https://clearhead.us/vocab/actions/v4#Context"/>
    <rdfs:comment xml:lang="en">Inverse of contextBroader. Enables queries to find all child contexts.</rdfs:comment>
    <rdfs:label xml:lang="en">context narrower</rdfs:label>
    <skos:definition xml:lang="en">Relates a Context to its children in the context hierarchy.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://clearhead.us/vocab/actions/v4#hasDoDateTime">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:subPropertyOf rdf:resource="https://www.commoncoreontologies.org/ont00001767"/>
    <rdfs:domain rdf:resource="https://www.commoncoreontologies.org/ont00000228"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    <rdfs:comment xml:lang="en">Maps to the "@" syntax in the .actions file format. Specializes CCO has datetime value for scheduling purposes.</rdfs:comment>
    <rdfs:label xml:lang="en">has do date time</rdfs:label>
    <skos:definition xml:lang="en">Relates a Planned Act to the date/time when it should be executed.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://clearhead.us/vocab/actions/v4#hasPriority">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="https://www.commoncoreontologies.org/ont00000965"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <rdfs:comment xml:lang="en">Maps to the "!" syntax in the .actions file format. 1=Urgent+Important, 2=Important+NotUrgent, 3=Urgent+NotImportant, 4=NotUrgent+NotImportant.</rdfs:comment>
    <rdfs:label xml:lang="en">has priority</rdfs:label>
    <skos:definition xml:lang="en">Relates a Plan to its priority level (1-4, Eisenhower Matrix).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://clearhead.us/vocab/actions/v4#hasCreatedDateTime">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:subPropertyOf rdf:resource="https://www.commoncoreontologies.org/ont00001767"/>
    <rdfs:domain rdf:resource="https://www.commoncoreontologies.org/ont00000974"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    <rdfs:comment xml:lang="en">Maps to the "^" syntax in the .actions file format. Can be derived from UUIDv7 if not explicitly set.</rdfs:comment>
    <rdfs:label xml:lang="en">has created date time</rdfs:label>
    <skos:definition xml:lang="en">Relates an entity in the action model to the date/time when it was first created.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://clearhead.us/vocab/actions/v4#NotStarted">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://www.commoncoreontologies.org/ont00000203"/>
    <rdfs:comment xml:lang="en">The Planned Act has not begun execution. File format: [ ]</rdfs:comment>
    <rdfs:label xml:lang="en">Not Started</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://clearhead.us/vocab/actions/v4#contextBroader">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:inverseOf rdf:resource="https://clearhead.us/vocab/actions/v4#contextNarrower"/>
    <rdfs:domain rdf:resource="https://clearhead.us/vocab/actions/v4#Context"/>
    <rdfs:range rdf:resource="https://clearhead.us/vocab/actions/v4#Context"/>
    <rdfs:comment xml:lang="en">Enables tag hierarchies where child contexts inherit from parents. Similar to SKOS broader concept. Example: +neovim contextBroader +terminal contextBroader +computer.</rdfs:comment>
    <rdfs:label xml:lang="en">context broader</rdfs:label>
    <skos:definition xml:lang="en">Relates a Context to its parent in the context hierarchy.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://clearhead.us/vocab/actions/v4#hasCompletedDateTime">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:subPropertyOf rdf:resource="https://www.commoncoreontologies.org/ont00001767"/>
    <rdfs:domain rdf:resource="https://www.commoncoreontologies.org/ont00000228"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    <rdfs:comment xml:lang="en">Maps to the "%" syntax in the .actions file format. Should only be present when status is Completed.</rdfs:comment>
    <rdfs:label xml:lang="en">has completed date time</rdfs:label>
    <skos:definition xml:lang="en">Relates a PlannedAct to the date/time when it was completed.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000974">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment xml:lang="en">In this vocabulary: Represents an action definition or task template. Maps to "Action" in the .actions file format.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000228">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment xml:lang="en">In this vocabulary: Represents an action instance - the actual execution of a plan. For recurring actions, one Plan produces multiple Planned Acts.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00001942">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:comment xml:lang="en">In this vocabulary: Links a Plan to the Planned Acts it prescribes. One Plan can prescribe many Planned Acts (e.g., recurring actions).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://clearhead.us/vocab/actions/v4#Completed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://www.commoncoreontologies.org/ont00000203"/>
    <rdfs:comment xml:lang="en">The Planned Act finished successfully. Terminal state. File format: [x]</rdfs:comment>
    <rdfs:label xml:lang="en">Completed</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://clearhead.us/vocab/actions/v4#hasRecurrenceRule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000001"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment xml:lang="en">Maps to the "R:" syntax in the .actions file format. When present, the Plan generates multiple PlannedActs according to the recurrence rule.</rdfs:comment>
    <rdfs:label xml:lang="en">has recurrence rule</rdfs:label>
    <skos:definition xml:lang="en">Relates a Plan to an RFC 5545 RRULE string defining recurrence pattern.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://clearhead.us/vocab/actions/v4#hasSequentialChildren">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="https://www.commoncoreontologies.org/ont00000974"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:comment xml:lang="en">Maps to the "~" syntax in the .actions file format. When true, each child Plan implicitly depends on the previous sibling completing.</rdfs:comment>
    <rdfs:label xml:lang="en">has sequential children</rdfs:label>
    <skos:definition xml:lang="en">Indicates whether child Plans should be processed sequentially.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://clearhead.us/vocab/actions/v4#hasAlias">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000001"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment xml:lang="en">Maps to the "=" syntax in the .actions file format. Aliases provide stable references that persist when plan names change. Must be unique within workspace scope.</rdfs:comment>
    <rdfs:label xml:lang="en">has alias</rdfs:label>
    <skos:definition xml:lang="en">Relates a Plan to a human-readable alias that can be used for reference.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/dc/terms/modified">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://clearhead.us/vocab/actions/v4#FacilityContextType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://clearhead.us/vocab/actions/v4#ContextType"/>
    <rdfs:comment xml:lang="en">Physical locations required for execution. DSL syntax: +@office, +@home. Maps to CCO Facility.</rdfs:comment>
    <rdfs:label xml:lang="en">Facility Context Type</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://clearhead.us/vocab/actions/v4#Cancelled">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://www.commoncoreontologies.org/ont00000203"/>
    <rdfs:comment xml:lang="en">The Planned Act was abandoned without completion. Terminal state. File format: [_]</rdfs:comment>
    <rdfs:label xml:lang="en">Cancelled</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2001/XMLSchema#date">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Datatype"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00001775">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:comment xml:lang="en">In this vocabulary: Used for plan dependency ordering. A Plan that is_successor_of another Plan cannot proceed until the predecessor completes. Maps to the "&lt;" predecessor syntax in the .actions file format.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000476">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment xml:lang="en">In this vocabulary: Represents a project or story - the desired outcome that plans work toward. Maps to the "*" story/project marker in the .actions file format.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://clearhead.us/vocab/actions/v4#ContextType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment xml:lang="en">Enables typed contexts that can map to specific CCO classes. Examples: facility (@office), agent (@bob), tool (computer).</rdfs:comment>
    <rdfs:label xml:lang="en">Context Type</rdfs:label>
    <skos:definition xml:lang="en">A classification for Context entities (facility, agent, tool, etc.).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000203">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment xml:lang="en">In this vocabulary: Used for lifecycle status values of Planned Acts (NotStarted, InProgress, Completed, Blocked, Cancelled).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#definition">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://clearhead.us/vocab/actions/v4#ToolContextType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://clearhead.us/vocab/actions/v4#ContextType"/>
    <rdfs:comment xml:lang="en">Tools, equipment, or software required for execution. DSL syntax: +computer, +phone. Maps to CCO Artifact.</rdfs:comment>
    <rdfs:label xml:lang="en">Tool Context Type</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/dc/terms/created">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/dc/terms/creator">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
</rdf:RDF>
