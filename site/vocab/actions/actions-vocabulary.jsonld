[
  {
    "@id": "https://clearhead.us/vocab/actions/v4#hasSequentialChildren",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty",
      "http://www.w3.org/2002/07/owl#FunctionalProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Maps to the \"~\" syntax in the .actions file format. When true, each child Plan implicitly depends on the previous sibling completing."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00000974"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "has sequential children"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Indicates whether child Plans should be processed sequentially."
      }
    ]
  },
  {
    "@id": "https://clearhead.us/vocab/actions/v4#hasExternalOccurrenceKey",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty",
      "http://www.w3.org/2002/07/owl#FunctionalProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Optional source-agnostic external occurrence identifier within a schedule series. For ICS integrations this typically maps from RECURRENCE-ID or canonicalized occurrence datetime."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://clearhead.us/vocab/actions/v4#Action"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "has external occurrence key"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Relates an Action to an external occurrence-level identifier when one exists."
      }
    ]
  },
  {
    "@id": "https://clearhead.us/vocab/actions/v4#ToolContextType",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://clearhead.us/vocab/actions/v4#ContextType"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Tools, equipment, or software required for execution. DSL syntax: +computer, +phone. Maps to CCO Artifact."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Tool Context Type"
      }
    ]
  },
  {
    "@id": "https://clearhead.us/vocab/actions/v4#Blocked",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://www.commoncoreontologies.org/ont00000203"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "The Action cannot proceed due to an external dependency or blocker. File format: [=]"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Blocked"
      }
    ]
  },
  {
    "@id": "http://purl.obolibrary.org/obo/BFO_0000050",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "In this vocabulary: Plans are part_of Charters (scope containment)."
      }
    ]
  },
  {
    "@id": "https://www.commoncoreontologies.org/ont00000974",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "In this vocabulary: Represents an action definition or task template. Maps to \"Action\" in the .actions file format."
      }
    ]
  },
  {
    "@id": "http://www.w3.org/2004/02/skos/core#definition",
    "@type": [
      "http://www.w3.org/2002/07/owl#AnnotationProperty"
    ]
  },
  {
    "@id": "https://clearhead.us/vocab/actions/v4#hasDueDateTime",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Maps to the \":\" syntax in the .actions file format. The deadline by which this act must be done — distinct from hasScheduledDateTime (when the agent plans to do it). For recurring plans, this is computed from the due-recurrence rule during act expansion. Example: garbage is due Monday morning (:), but planned Sunday night (@)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://clearhead.us/vocab/actions/v4#Action"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "has due date time"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#dateTime"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subPropertyOf": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00001767"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Relates an Action to the date/time by which it must be completed."
      }
    ]
  },
  {
    "@id": "https://www.commoncoreontologies.org/ont00001868",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "In this vocabulary: Links an Action to its Event Status Nominal ICE (lifecycle phase)."
      }
    ]
  },
  {
    "@id": "http://purl.obolibrary.org/obo/BFO_0000051",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "In this vocabulary: Plan decomposition - parent actions have child actions as parts. Also Charter → Plan containment. Maps to the \">\" children syntax in the .actions file format."
      }
    ]
  },
  {
    "@id": "https://clearhead.us/vocab/actions/v4",
    "@type": [
      "http://www.w3.org/2002/07/owl#Ontology"
    ],
    "http://purl.org/dc/terms/created": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#date",
        "@value": "2025-01-21"
      }
    ],
    "http://purl.org/dc/terms/creator": [
      {
        "@value": "Darrion Burgess"
      }
    ],
    "http://purl.org/dc/terms/modified": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#date",
        "@value": "2026-04-12"
      }
    ],
    "http://purl.org/dc/terms/title": [
      {
        "@value": "CCO Extension for Intention Information Entities"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A disciplined extension to the Common Core Ontologies (CCO) for modeling\nintentional planning and execution.\n\nThis ontology fills genuine gaps in CCO's coverage of intention information entities:\n- Charter: A Prescriptive ICE declaring scope of directed concern (CCO has Plan and Objective but no scope class)\n- inServiceOf: A teleological relation linking Prescriptive ICEs to the Objectives they serve (CCO lacks this)\n\nCCO modules imported (via owl:imports):\n- InformationEntityOntology: Prescriptive ICE (ont00000965), Event Status Nominal ICE (ont00000203), prescribes (ont00001942), is_measured_by_nominal (ont00001868)\n- AgentOntology: Plan (ont00000974), Objective (ont00000476)\n- EventOntology: Act (ont00000832)\n\nThis ontology introduces Action as the canonical execution entity while remaining aligned\nwith CCO's occurrent/event modeling where appropriate.\n\nTransitively available via CCO import chain:\n- ExtendedRelationOntology: is_successor_of (ont00001775)\n- TimeOntology, GeospatialOntology, BFO 2020\n\nInformationEntityOntology is imported directly (not just transitively) because Prescriptive ICE\n(ont00000965) is the foundational parent class for Charter, Context, Plan, and Objective —\nall core vocabulary classes. Making this dependency explicit ensures Protégé resolves it\ncorrectly without relying on transitive catalog lookups.\n\nLocal resolution: see catalog-v001.xml for IRI → local file mappings.\nFor full CCO definitions, see: https://github.com/CommonCoreOntology/CommonCoreOntologies\nFor design rationale, see: V4_DESIGN.md"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "CCO Extension for Intention Information Entities"
      }
    ],
    "http://www.w3.org/2002/07/owl#imports": [
      {
        "@id": "https://www.commoncoreontologies.org/InformationEntityOntology"
      },
      {
        "@id": "https://www.commoncoreontologies.org/AgentOntology"
      },
      {
        "@id": "https://www.commoncoreontologies.org/EventOntology"
      }
    ],
    "http://www.w3.org/2002/07/owl#versionIRI": [
      {
        "@id": "https://clearhead.us/vocab/actions/v4/4.3.0"
      }
    ],
    "http://www.w3.org/2002/07/owl#versionInfo": [
      {
        "@value": "4.3.0"
      }
    ]
  },
  {
    "@id": "https://clearhead.us/vocab/actions/v4#FacilityContextType",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://clearhead.us/vocab/actions/v4#ContextType"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Physical locations required for execution. DSL syntax: +@office, +@home. Maps to CCO Facility."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Facility Context Type"
      }
    ]
  },
  {
    "@id": "https://clearhead.us/vocab/actions/v4#hasCompletedDateTime",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Maps to the \"%\" syntax in the .actions file format. Should only be present when status is Completed."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://clearhead.us/vocab/actions/v4#Action"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "has completed date time"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#dateTime"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subPropertyOf": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00001767"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Relates an Action to the date/time when it was completed."
      }
    ]
  },
  {
    "@id": "https://clearhead.us/vocab/actions/v4#CategoryContextType",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://clearhead.us/vocab/actions/v4#ContextType"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "General categories or domains. DSL syntax: +work, +personal, +urgent. For organization and filtering."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Category Context Type"
      }
    ]
  },
  {
    "@id": "https://www.commoncoreontologies.org/ont00001942",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "In this vocabulary: Links a Plan to the Actions it prescribes. One Plan can prescribe many Actions (for example recurring or schedule-derived actions)."
      }
    ]
  },
  {
    "@id": "https://clearhead.us/vocab/actions/v4#Context",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Context represents execution requirements following Getting Things Done (GTD) methodology. Contexts support hierarchical relationships for tag organization and inheritance. Maps to \"+\" syntax in .actions file format."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Context"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00000965"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "A resource, location, tool, or person required for plan execution (GTD context methodology)."
      }
    ]
  },
  {
    "@id": "https://clearhead.us/vocab/actions/v4#Charter",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A Charter establishes the boundary of responsibility or interest without prescribing specific acts (that's Plan) or target states (that's Objective). It answers \"what domain am I responsible for?\"\n\nExamples: \"Health & Fitness\", \"Career Development\", \"Home Maintenance\"\n\nCharters contain Plans and Actions (via has_part), and Plans serve Objectives (via inServiceOf). This creates the pipeline: Charter (scope) → Plan (prescription) → Action (execution).\n\nCCO has Plan and Objective but lacks a class for scope-of-concern declarations. Charter fills this genuine gap."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Charter"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00000965"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "A Prescriptive Information Content Entity that declares the scope of directed concern for an agent or organization."
      }
    ]
  },
  {
    "@id": "http://www.w3.org/2001/XMLSchema#date",
    "@type": [
      "http://www.w3.org/2000/01/rdf-schema#Datatype"
    ]
  },
  {
    "@id": "https://www.commoncoreontologies.org/ont00000228",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Imported CCO class retained for reference. In this vocabulary, actions:Action is the canonical execution entity used by data contracts and examples."
      }
    ]
  },
  {
    "@id": "https://clearhead.us/vocab/actions/v4#hasContextIdentifier",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty",
      "http://www.w3.org/2002/07/owl#FunctionalProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Maps the DSL tag name (e.g., \"work\", \"computer\") to the Context entity. Must be unique within workspace scope."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://clearhead.us/vocab/actions/v4#Context"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "has context identifier"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "The string identifier used to reference this context in the DSL."
      }
    ]
  },
  {
    "@id": "https://clearhead.us/vocab/actions/v4#NotStarted",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://www.commoncoreontologies.org/ont00000203"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "The Action has not begun execution. File format: [ ]"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Not Started"
      }
    ]
  },
  {
    "@id": "https://clearhead.us/vocab/actions/v4#hasPriority",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty",
      "http://www.w3.org/2002/07/owl#FunctionalProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Maps to the \"!\" syntax in the .actions file format. 1=Urgent+Important, 2=Important+NotUrgent, 3=Urgent+NotImportant, 4=NotUrgent+NotImportant."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00000965"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "has priority"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#integer"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Relates a Plan to its priority level (1-4, Eisenhower Matrix)."
      }
    ]
  },
  {
    "@id": "https://clearhead.us/vocab/actions/v4#hasAlias",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Maps to the \"=\" syntax in the .actions file format. Aliases provide stable references that persist when plan names change. Must be unique within workspace scope."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "http://purl.obolibrary.org/obo/BFO_0000001"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "has alias"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Relates a Plan to a human-readable alias that can be used for reference."
      }
    ]
  },
  {
    "@id": "https://clearhead.us/vocab/actions/v4#hasDurationMinutes",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Maps to the \"D\" syntax in the .actions file format (D60 = 60 minutes). Used for time blocking and capacity planning."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://clearhead.us/vocab/actions/v4#Action"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "has duration minutes"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#integer"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Relates an Action to its duration in minutes."
      }
    ]
  },
  {
    "@id": "https://clearhead.us/vocab/actions/v4#Completed",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://www.commoncoreontologies.org/ont00000203"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "The Action finished successfully. Terminal state. File format: [x]"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Completed"
      }
    ]
  },
  {
    "@id": "https://www.commoncoreontologies.org/ont00000476",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "In this vocabulary: Represents a project or story - the desired outcome that plans work toward. Maps to the \"*\" story/project marker in the .actions file format."
      }
    ]
  },
  {
    "@id": "https://clearhead.us/vocab/actions/v4#hasExternalScheduleId",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty",
      "http://www.w3.org/2002/07/owl#FunctionalProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Optional source-agnostic external schedule series identifier for acts generated from integration profiles (for example ICS UID mapping). Not required for ad-hoc acts."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://clearhead.us/vocab/actions/v4#Action"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "has external schedule id"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Relates an Action to an external schedule-series identifier when one exists."
      }
    ]
  },
  {
    "@id": "https://clearhead.us/vocab/actions/v4#hasRecurrenceRule",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Relates a Plan to recurrence semantics that may generate multiple related Actions in downstream expansion workflows."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "http://purl.obolibrary.org/obo/BFO_0000001"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "has recurrence rule"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Relates a Plan to an RFC 5545 RRULE string defining recurrence pattern."
      }
    ]
  },
  {
    "@id": "https://clearhead.us/vocab/actions/v4#hasDueRecurrenceRule",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Relates a Plan to recurrence semantics for deriving due-date streams. When present alongside hasRecurrenceRule, downstream expansion may produce distinct scheduled and due action streams."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00000974"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "has due recurrence rule"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Relates a Plan to an RFC 5545 RRULE string defining the recurrence pattern for when acts are due."
      }
    ]
  },
  {
    "@id": "https://www.commoncoreontologies.org/ont00000203",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "In this vocabulary: Used for lifecycle status values of Actions (NotStarted, InProgress, Completed, Blocked, Cancelled)."
      }
    ]
  },
  {
    "@id": "https://clearhead.us/vocab/actions/v4#contextNarrower",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Inverse of contextBroader. Enables queries to find all child contexts."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://clearhead.us/vocab/actions/v4#Context"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "context narrower"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://clearhead.us/vocab/actions/v4#Context"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Relates a Context to its children in the context hierarchy."
      }
    ]
  },
  {
    "@id": "https://clearhead.us/vocab/actions/v4#hasScheduledDateTime",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Maps to the \"@\" syntax in the .actions file format. The time the agent intends to perform this act — distinct from hasDueDateTime (when it must be done). For recurring plans, this is computed from the do-recurrence rule during act expansion."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://clearhead.us/vocab/actions/v4#Action"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "has scheduled date time"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#dateTime"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subPropertyOf": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00001767"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Relates an Action to the date/time when the agent intends to execute it."
      }
    ]
  },
  {
    "@id": "http://purl.org/dc/terms/creator",
    "@type": [
      "http://www.w3.org/2002/07/owl#AnnotationProperty"
    ]
  },
  {
    "@id": "https://clearhead.us/vocab/actions/v4#inServiceOf",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A teleological relation filling a genuine CCO gap: CCO has prescribes (plan→act) but lacks a relation for \"this prescriptive entity serves that objective.\" Domain is Prescriptive ICE so both Plans and Charters can serve Objectives.\n\nMaps to the \"*\" marker in the .actions file format. A Plan may serve zero objectives (standalone task) or multiple objectives."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00000965"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "in service of"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00000476"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Relates a Prescriptive Information Content Entity to the Objective it works toward."
      }
    ]
  },
  {
    "@id": "http://purl.org/dc/terms/title",
    "@type": [
      "http://www.w3.org/2002/07/owl#AnnotationProperty"
    ]
  },
  {
    "@id": "https://clearhead.us/vocab/actions/v4#Action",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "An Action is the canonical execution entity in this vocabulary. Actions may be prescribed by a Plan or exist directly within a Charter as ad-hoc work items. This class replaces PlannedAct as the primary task-level semantic surface for v4 consumers."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Action"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "An execution-level work item that can carry status, timing, duration, dependency, and external schedule identity semantics."
      }
    ]
  },
  {
    "@id": "https://clearhead.us/vocab/actions/v4#hasSubCharter",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A Charter contains another Charter as a sub-scope. Specializes BFO has_part for Charter hierarchy. Example: \"Health\" hasSubCharter \"Fitness\" hasSubCharter \"Gym Training\"."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://clearhead.us/vocab/actions/v4#Charter"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "has sub charter"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://clearhead.us/vocab/actions/v4#Charter"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subPropertyOf": [
      {
        "@id": "http://purl.obolibrary.org/obo/BFO_0000051"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Relates a Charter to a Charter that represents a narrower scope of directed concern within it."
      }
    ]
  },
  {
    "@id": "https://clearhead.us/vocab/actions/v4#Cancelled",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://www.commoncoreontologies.org/ont00000203"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "The Action was abandoned without completion. Terminal state. File format: [_]"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Cancelled"
      }
    ]
  },
  {
    "@id": "https://clearhead.us/vocab/actions/v4#InProgress",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://www.commoncoreontologies.org/ont00000203"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "The Action is currently being executed. File format: [-]"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "In Progress"
      }
    ]
  },
  {
    "@id": "https://www.commoncoreontologies.org/ont00001775",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "In this vocabulary: Used for plan dependency ordering. A Plan that is_successor_of another Plan cannot proceed until the predecessor completes. Maps to the \"<\" predecessor syntax in the .actions file format."
      }
    ]
  },
  {
    "@id": "https://clearhead.us/vocab/actions/v4#hasUUID",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty",
      "http://www.w3.org/2002/07/owl#FunctionalProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Maps to the \"#\" syntax in the .actions file format. Provides universal uniqueness across systems and time. UUIDv7 encodes creation timestamp."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00000974"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "has UUID"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Relates an entity in the action model to its unique identifier (UUIDv7 preferred)."
      }
    ]
  },
  {
    "@id": "https://clearhead.us/vocab/actions/v4#ContextType",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Enables typed contexts that can map to specific CCO classes. Examples: facility (@office), agent (@bob), tool (computer)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Context Type"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "A classification for Context entities (facility, agent, tool, etc.)."
      }
    ]
  },
  {
    "@id": "https://clearhead.us/vocab/actions/v4#AgentContextType",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://clearhead.us/vocab/actions/v4#ContextType"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "People required for execution. DSL syntax: +@bob, +@manager. Maps to CCO Agent."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Agent Context Type"
      }
    ]
  },
  {
    "@id": "https://www.commoncoreontologies.org/ont00001767",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "In this vocabulary: Parent property for hasScheduledDateTime, hasDueDateTime, hasCompletedDateTime, hasCreatedDateTime."
      }
    ]
  },
  {
    "@id": "https://clearhead.us/vocab/actions/v4#contextBroader",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Enables tag hierarchies where child contexts inherit from parents. Similar to SKOS broader concept. Example: +neovim contextBroader +terminal contextBroader +computer."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://clearhead.us/vocab/actions/v4#Context"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "context broader"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://clearhead.us/vocab/actions/v4#Context"
      }
    ],
    "http://www.w3.org/2002/07/owl#inverseOf": [
      {
        "@id": "https://clearhead.us/vocab/actions/v4#contextNarrower"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Relates a Context to its parent in the context hierarchy."
      }
    ]
  },
  {
    "@id": "https://clearhead.us/vocab/actions/v4#requiresContext",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Maps to the \"+\" syntax in the .actions file format. Context entities enable tag hierarchies and typed contexts (facilities, agents, tools, etc.)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00000965"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "requires context"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://clearhead.us/vocab/actions/v4#Context"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Relates a Plan to a Context entity required for execution."
      }
    ]
  },
  {
    "@id": "https://clearhead.us/vocab/actions/v4#hasContextType",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Enables typed contexts for better organization and CCO alignment."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://clearhead.us/vocab/actions/v4#Context"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "has context type"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://clearhead.us/vocab/actions/v4#ContextType"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Relates a Context to its type classification."
      }
    ]
  },
  {
    "@id": "http://purl.org/dc/terms/created",
    "@type": [
      "http://www.w3.org/2002/07/owl#AnnotationProperty"
    ]
  },
  {
    "@id": "http://purl.org/dc/terms/modified",
    "@type": [
      "http://www.w3.org/2002/07/owl#AnnotationProperty"
    ]
  },
  {
    "@id": "https://clearhead.us/vocab/actions/v4#hasCreatedDateTime",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Maps to the \"^\" syntax in the .actions file format. Can be derived from UUIDv7 if not explicitly set."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00000974"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "has created date time"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#dateTime"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subPropertyOf": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00001767"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Relates an entity in the action model to the date/time when it was first created."
      }
    ]
  }
]