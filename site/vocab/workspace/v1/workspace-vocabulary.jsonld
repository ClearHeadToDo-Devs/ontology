  {
    "@id": "https://clearhead.us/vocab/workspace/v1",
    "@type": [
      "http://www.w3.org/2002/07/owl#Ontology"
    ],
    "http://purl.org/dc/elements/1.1/created": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#date",
        "@value": "2026-05-30"
      }
    ],
    "http://purl.org/dc/elements/1.1/creator": [
      {
        "@value": "Darrion Burgess"
      }
    ],
    "http://purl.org/dc/elements/1.1/title": [
      {
        "@value": "Clearhead Workspace Vocabulary"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Application-level vocabulary for clearhead workspace snapshots.\n\nImports and extends the actions: vocabulary with predicates describing filesystem-layer\nfacts about actions in a specific workspace: their source file and line number. These are\nworkspace-snapshot properties, not ontological properties of the action itself.\n\nThese triples are stored in the working graph at load time by load_domain_model in\nclearhead-core, valid for the current workspace snapshot. They enable SPARQL queries\nto return file+line for editor integration (qflist, jump-to-source)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Clearhead Workspace Vocabulary"
      }
    ],
    "http://www.w3.org/2002/07/owl#imports": [
      {
        "@id": "https://clearhead.us/vocab/actions/v4"
      }
    ],
    "http://www.w3.org/2002/07/owl#versionIRI": [
      {
        "@id": "https://clearhead.us/vocab/workspace/v1/1.0.0"
      }
    ],
    "http://www.w3.org/2002/07/owl#versionInfo": [
      {
        "@value": "1.0.0"
      }
    ]
  }
]