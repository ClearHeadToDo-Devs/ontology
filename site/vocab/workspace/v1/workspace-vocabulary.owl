<?xml version="1.0"?>
<rdf:RDF xmlns="https://clearhead.us/vocab/workspace/v1#"
     xml:base="https://clearhead.us/vocab/workspace/v1"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:actions="https://clearhead.us/vocab/actions/v4#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">

    <owl:Ontology rdf:about="https://clearhead.us/vocab/workspace/v1">
        <owl:versionIRI rdf:resource="https://clearhead.us/vocab/workspace/v1/1.0.0"/>
        <owl:imports rdf:resource="https://clearhead.us/vocab/actions/v4"/>
        <dc:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-30</dc:created>
        <dc:creator>Darrion Burgess</dc:creator>
        <dc:title>Clearhead Workspace Vocabulary</dc:title>
        <rdfs:comment xml:lang="en">Application-level vocabulary for clearhead workspace snapshots.

Imports and extends the actions: vocabulary with predicates describing filesystem-layer
facts about actions in a specific workspace: their source file and line number. These are
workspace-snapshot properties, not ontological properties of the action itself.

These triples are stored in the working graph at load time by load_domain_model in
clearhead-core, valid for the current workspace snapshot. They enable SPARQL queries
to return file+line for editor integration (qflist, jump-to-source).</rdfs:comment>
        <rdfs:label xml:lang="en">Clearhead Workspace Vocabulary</rdfs:label>
        <owl:versionInfo>1.0.0</owl:versionInfo>
    </owl:Ontology>


    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatype Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <!-- https://clearhead.us/vocab/workspace/v1#hasSourceFile -->

    <owl:DatatypeProperty rdf:about="https://clearhead.us/vocab/workspace/v1#hasSourceFile">
        <rdfs:domain rdf:resource="https://clearhead.us/vocab/actions/v4#Action"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">hasSourceFile</rdfs:label>
        <rdfs:comment xml:lang="en">Relative path from the workspace root to the .actions file containing this action.</rdfs:comment>
    </owl:DatatypeProperty>


    <!-- https://clearhead.us/vocab/workspace/v1#hasSourceLine -->

    <owl:DatatypeProperty rdf:about="https://clearhead.us/vocab/workspace/v1#hasSourceLine">
        <rdfs:domain rdf:resource="https://clearhead.us/vocab/actions/v4#Action"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label xml:lang="en">hasSourceLine</rdfs:label>
        <rdfs:comment xml:lang="en">1-based line number of this action within its source file.</rdfs:comment>
    </owl:DatatypeProperty>

</rdf:RDF>
