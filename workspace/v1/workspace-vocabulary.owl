<?xml version="1.0"?>
<rdf:RDF xmlns="https://clearhead.us/vocab/workspace/v1#"
     xml:base="https://clearhead.us/vocab/workspace/v1"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:actions="https://clearhead.us/vocab/actions/v4#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">

    <owl:Ontology rdf:about="https://clearhead.us/vocab/workspace/v1">
        <owl:versionIRI rdf:resource="https://clearhead.us/vocab/workspace/v1/1.0.0"/>
        <owl:imports rdf:resource="https://clearhead.us/vocab/actions/v4"/>
        <dc:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-30</dc:created>
        <dc:creator>Darrion Burgess</dc:creator>
        <dc:title>Clearhead Workspace Vocabulary</dc:title>
        <rdfs:comment xml:lang="en">Application-level vocabulary for clearhead workspaces.

Declares the Workspace class (a named, UUID-identified collection of charters and
actions) and datatype properties describing filesystem-layer facts about actions
(source file path, source line number).

The Workspace class is used to project workspace identity into the RDF named graph
so that reference resolution can find a workspace by alias without decoding graph
URIs. Source location properties are workspace-snapshot facts, not ontological
properties of the action itself — they are valid for the current filesystem state
and enable editor integration (qflist, jump-to-source).</rdfs:comment>
        <rdfs:label xml:lang="en">Clearhead Workspace Vocabulary</rdfs:label>
        <owl:versionInfo>1.0.0</owl:versionInfo>
    </owl:Ontology>


    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatype Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <!-- https://clearhead.us/vocab/workspace/v1#Workspace -->

    <owl:Class rdf:about="https://clearhead.us/vocab/workspace/v1#Workspace">
        <rdfs:label xml:lang="en">Workspace</rdfs:label>
        <rdfs:comment xml:lang="en">A clearhead workspace — a named, addressable collection of charters and actions with a stable UUID identity. The named graph URI is urn:clearhead:workspace:&lt;uuid&gt;. Identity (alias, label) is written once by clearhead init into .clearhead/config.json and projected as RDF triples by insert_workspace_metadata so reference resolution can find a workspace by alias across named graphs.</rdfs:comment>
    </owl:Class>


    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatype Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <!-- https://clearhead.us/vocab/workspace/v1#hasSourceFile -->

    <owl:DatatypeProperty rdf:about="https://clearhead.us/vocab/workspace/v1#hasSourceFile">
        <rdfs:domain rdf:resource="https://clearhead.us/vocab/actions/v4#Action"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">hasSourceFile</rdfs:label>
        <rdfs:comment xml:lang="en">Relative path from the workspace root to the .actions file containing this action.</rdfs:comment>
    </owl:DatatypeProperty>


    <!-- https://clearhead.us/vocab/workspace/v1#hasSourceLine -->

    <owl:DatatypeProperty rdf:about="https://clearhead.us/vocab/workspace/v1#hasSourceLine">
        <rdfs:domain rdf:resource="https://clearhead.us/vocab/actions/v4#Action"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label xml:lang="en">hasSourceLine</rdfs:label>
        <rdfs:comment xml:lang="en">1-based line number of this action within its source file.</rdfs:comment>
    </owl:DatatypeProperty>

</rdf:RDF>
