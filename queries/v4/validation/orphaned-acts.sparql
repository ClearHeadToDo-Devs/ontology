# =============================================================================
# Query: Orphaned Actions
# =============================================================================
# Purpose: Find Actions that are genuinely unanchored — not prescribed by any
#          Plan AND not directly contained in a Charter.
#          Ad-hoc actions (bfo:BFO_0000051 from a Charter, no Plan) are NOT
#          orphaned; they are a first-class pattern in the model.
# Returns: orphaned_act, status
# Usage: Data validation and integrity checking
# =============================================================================

PREFIX actions: <https://clearhead.us/vocab/actions/v4#>
PREFIX cco: <https://www.commoncoreontologies.org/>
PREFIX bfo: <http://purl.obolibrary.org/obo/>

SELECT ?orphaned_act ?status WHERE {
    # Find all Actions
    ?orphaned_act a actions:Action ;
                  cco:ont00001868 ?status .  # is_measured_by_nominal

    # No Plan prescribes this action
    FILTER NOT EXISTS {
        ?plan a cco:ont00000974 ;
              cco:ont00001942 ?orphaned_act .
    }

    # AND not directly contained in a Charter (ad-hoc actions are legitimate)
    FILTER NOT EXISTS {
        ?charter a actions:Charter ;
                 bfo:BFO_0000051 ?orphaned_act .
    }
}
ORDER BY ?orphaned_act
