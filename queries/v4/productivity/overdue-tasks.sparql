# =============================================================================
# Query: Overdue Actions
# =============================================================================
# Purpose: Find Actions that are past their due date and not completed
# Parameters:
#   - ?CUTOFF_DATE: Current date/time (e.g., "2025-01-20T00:00:00Z"^^xsd:dateTime)
# Returns: act, plan_name, due_date, scheduled_at, status, priority_level, contexts, schedule_id
# Usage: Daily/weekly overdue action review
# Notes: Due dates are act-level metadata (post-Decision-21 source of truth).
#        plan_name is optional — ad-hoc actions may have no prescribing plan.
#        schedule_id surfaces the ICS/external series for schedule-derived actions.
# =============================================================================

PREFIX actions: <https://clearhead.us/vocab/actions/v4#>
PREFIX cco: <https://www.commoncoreontologies.org/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

SELECT ?act ?plan_name ?due_date ?scheduled_at ?status ?priority_level ?contexts ?schedule_id WHERE {
    # Find actions that are not completed or cancelled
    ?act a actions:Action ;
         cco:ont00001868 ?status .  # is_measured_by_nominal

    FILTER(?status != actions:Completed && ?status != actions:Cancelled)

    # Due date is act-level metadata (source of truth post-Decision-21)
    ?act actions:hasDueDateTime ?due_date .

    # Filter for overdue (parameter substitution needed)
    # Example: FILTER(?due_date < "2025-01-20T00:00:00Z"^^xsd:dateTime)
    # FILTER(?due_date < ?CUTOFF_DATE)

    # Optional scheduled time (independent from due date)
    OPTIONAL { ?act actions:hasScheduledDateTime ?scheduled_at }

    # Optional external schedule series identifier (ICS/calendar integration)
    OPTIONAL { ?act actions:hasExternalScheduleId ?schedule_id }

    # Optional plan (ad-hoc actions may have none)
    OPTIONAL {
        ?plan cco:ont00001942 ?act ;
              rdfs:label ?plan_name .

        OPTIONAL { ?plan actions:hasPriority ?priority_level }

        OPTIONAL {
            SELECT ?plan (GROUP_CONCAT(?context; separator=", ") AS ?contexts) WHERE {
                ?plan actions:requiresContext ?context .
            }
            GROUP BY ?plan
        }
    }
}
ORDER BY ?priority_level ?due_date
