# =============================================================================
# Query: Schedule Series
# =============================================================================
# Purpose: Find all Actions derived from an external schedule series (ICS or
#          other calendar source). Groups occurrences by their externalScheduleId
#          to expose the full expansion history of a recurring external schedule.
# Parameters:
#   - ?SCHEDULE_ID: External schedule series identifier (e.g., ICS UID).
#                   Omit the FILTER line to retrieve all schedule-derived actions.
# Returns: schedule_id, occurrence_key, act, plan_name, status, scheduled_at, due_date
# Usage: Calendar integration review, ICS sync reconciliation, series audit
# Notes: Post-Decision-21 recurrence is owned by external schedules (ICS/vdir).
#        Actions carry hasExternalScheduleId (series) and hasExternalOccurrenceKey
#        (per-occurrence RECURRENCE-ID or canonicalized datetime).
# =============================================================================

PREFIX actions: <https://clearhead.us/vocab/actions/v4#>
PREFIX cco: <https://www.commoncoreontologies.org/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?schedule_id ?occurrence_key ?act ?plan_name ?status ?scheduled_at ?due_date WHERE {
    # All actions linked to an external schedule series
    ?act a actions:Action ;
         actions:hasExternalScheduleId ?schedule_id ;
         cco:ont00001868 ?status .  # is_measured_by_nominal

    # Optional occurrence key within the series (RECURRENCE-ID or occurrence datetime)
    OPTIONAL { ?act actions:hasExternalOccurrenceKey ?occurrence_key }

    # Optional prescribing plan template
    OPTIONAL {
        ?plan cco:ont00001942 ?act ;
              rdfs:label ?plan_name .
    }

    OPTIONAL { ?act actions:hasScheduledDateTime ?scheduled_at }
    OPTIONAL { ?act actions:hasDueDateTime ?due_date }

    # Uncomment to filter by a specific schedule series:
    # FILTER(?schedule_id = ?SCHEDULE_ID)
}
ORDER BY ?schedule_id ?scheduled_at ?occurrence_key
