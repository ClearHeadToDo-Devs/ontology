@prefix actions: <https://clearhead.us/vocab/actions/v4#> .
@prefix cco: <https://www.commoncoreontologies.org/> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# Ad-hoc Actions Example (v4.3.0)
# =============================================================================
# Demonstrates Actions that live directly under a Charter without a Plan.
# This is the "quick capture" pattern: single, non-recurring tasks that
# don't warrant a full Plan template.
#
# Ad-hoc actions are NOT orphaned — they are first-class citizens in the
# Charter hierarchy. They differ from plan-prescribed actions in that:
#   - No Plan prescribes them (no cco:ont00001942 relationship)
#   - They are scoped directly via bfo:BFO_0000051 (hasPart) from a Charter
#   - They carry no hasExternalScheduleId (no ICS/calendar integration)
#
# The orphaned-acts.sparql query explicitly excludes Charter-scoped actions
# from the orphan check for this reason.
#
# Use case: personal inbox capture, quick tasks, one-off reminders
# Conforms to: actions-shapes-v4.ttl, actions-vocabulary.owl v4.3.0
# =============================================================================

# Personal charter with sub-charters and direct ad-hoc actions
<urn:charter:personal> a actions:Charter ;
    rdfs:label "Personal" ;
    actions:hasSubCharter <urn:charter:personal/admin> ;
    # Ad-hoc actions at the top-level charter scope
    bfo:BFO_0000051 <urn:action:buy-birthday-gift> ;
    bfo:BFO_0000051 <urn:action:call-dentist> .

<urn:charter:personal/admin> a actions:Charter ;
    rdfs:label "Personal Admin" ;
    # Ad-hoc actions at the sub-charter scope
    bfo:BFO_0000051 <urn:action:renew-car-registration> ;
    bfo:BFO_0000051 <urn:action:update-will-with-lawyer> .

# =============================================================================
# Ad-hoc Actions: top-level charter scope
# =============================================================================

<urn:action:buy-birthday-gift> a actions:Action ;
    rdfs:label "Buy birthday gift for mom" ;
    cco:ont00001868 actions:NotStarted ;
    actions:hasScheduledDateTime "2026-05-18T10:00:00Z"^^xsd:dateTime ;
    actions:hasDueDateTime       "2026-05-20T23:59:00Z"^^xsd:dateTime ;
    actions:hasDurationMinutes 60 .

<urn:action:call-dentist> a actions:Action ;
    rdfs:label "Call dentist to schedule cleaning" ;
    cco:ont00001868 actions:NotStarted ;
    actions:hasDurationMinutes 10 .

# =============================================================================
# Ad-hoc Actions: sub-charter scope
# =============================================================================

<urn:action:renew-car-registration> a actions:Action ;
    rdfs:label "Renew car registration" ;
    cco:ont00001868 actions:InProgress ;
    actions:hasDueDateTime "2026-05-31T23:59:00Z"^^xsd:dateTime ;
    actions:hasDurationMinutes 20 .

<urn:action:update-will-with-lawyer> a actions:Action ;
    rdfs:label "Schedule meeting with lawyer to update will" ;
    cco:ont00001868 actions:NotStarted ;
    actions:hasDurationMinutes 30 .

# =============================================================================
# Plan-prescribed Action (for contrast)
# =============================================================================
# Even in an otherwise ad-hoc charter, some actions may come from a Plan
# (e.g., a recurring monthly review). The two patterns coexist naturally.

<urn:plan:monthly-finance-review> a cco:ont00000974 ;
    rdfs:label "Monthly personal finance review" ;
    actions:hasUUID "cccccccc-cccc-4ccc-8ccc-cccccccccccc" ;
    bfo:BFO_0000050 <urn:charter:personal/admin> ;
    cco:ont00001942 <urn:action:finance-review-may-2026> .

<urn:action:finance-review-may-2026> a actions:Action ;
    cco:ont00001868 actions:NotStarted ;
    actions:hasScheduledDateTime "2026-05-28T19:00:00Z"^^xsd:dateTime ;
    actions:hasDurationMinutes 45 .
