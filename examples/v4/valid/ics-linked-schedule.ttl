@prefix actions: <https://clearhead.us/vocab/actions/v4#> .
@prefix cco: <https://www.commoncoreontologies.org/> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# ICS-Linked Schedule Example (v4.3.0)
# =============================================================================
# Demonstrates Actions derived from external ICS/calendar schedules:
# - Plan template linked to a recurring weekly meeting (ICS UID as schedule ID)
# - Multiple Actions with hasExternalScheduleId (ICS UID) and
#   hasExternalOccurrenceKey (RECURRENCE-ID / canonicalized occurrence datetime)
# - A second plan/series for a monthly 1-on-1
# - An ad-hoc Action in the same Charter for contrast (no external schedule)
#
# This covers the post-Decision-21 recurrence model:
#   - Recurrence rules live in external schedules (ICS/vdir/khal)
#   - clearhead Plans serve as named templates
#   - Actions carry bridge fields (hasExternalScheduleId, hasExternalOccurrenceKey)
#     so the graph can be reconciled against the calendar source at any time
#
# Conforms to: actions-shapes-v4.ttl, actions-vocabulary.owl v4.3.0
# =============================================================================

# Work charter hierarchy
<urn:charter:work> a actions:Charter ;
    rdfs:label "Work" ;
    actions:hasSubCharter <urn:charter:work/clearhead> .

<urn:charter:work/clearhead> a actions:Charter ;
    rdfs:label "ClearHead Project" ;
    # Ad-hoc action directly in the sub-charter (no plan, no external schedule)
    bfo:BFO_0000051 <urn:action:ad-hoc-release-notes> .

# =============================================================================
# Plan Template: Weekly Team Standup
# =============================================================================
# The ICS UID "standup-weekly@work.example.com" is the canonical series ID.
# Each Action below represents one expanded occurrence from vdirsyncer/khal.

<urn:plan:weekly-standup> a cco:ont00000974 ;
    rdfs:label "Weekly team standup" ;
    actions:hasAlias "standup" ;
    actions:hasUUID "aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa" ;
    bfo:BFO_0000050 <urn:charter:work/clearhead> ;
    cco:ont00001942 <urn:action:standup-2026-05-12> ,
                    <urn:action:standup-2026-05-19> ,
                    <urn:action:standup-2026-05-26> .

# Occurrence 1: completed (2026-05-12)
<urn:action:standup-2026-05-12> a actions:Action ;
    cco:ont00001868 actions:Completed ;
    actions:hasScheduledDateTime "2026-05-12T09:00:00Z"^^xsd:dateTime ;
    actions:hasCompletedDateTime  "2026-05-12T09:28:00Z"^^xsd:dateTime ;
    actions:hasDurationMinutes 30 ;
    actions:hasExternalScheduleId   "standup-weekly@work.example.com" ;
    actions:hasExternalOccurrenceKey "20260512T090000Z" .

# Occurrence 2: not started (2026-05-19)
<urn:action:standup-2026-05-19> a actions:Action ;
    cco:ont00001868 actions:NotStarted ;
    actions:hasScheduledDateTime "2026-05-19T09:00:00Z"^^xsd:dateTime ;
    actions:hasDurationMinutes 30 ;
    actions:hasExternalScheduleId   "standup-weekly@work.example.com" ;
    actions:hasExternalOccurrenceKey "20260519T090000Z" .

# Occurrence 3: not started (2026-05-26)
<urn:action:standup-2026-05-26> a actions:Action ;
    cco:ont00001868 actions:NotStarted ;
    actions:hasScheduledDateTime "2026-05-26T09:00:00Z"^^xsd:dateTime ;
    actions:hasDurationMinutes 30 ;
    actions:hasExternalScheduleId   "standup-weekly@work.example.com" ;
    actions:hasExternalOccurrenceKey "20260526T090000Z" .

# =============================================================================
# Plan Template: Monthly 1-on-1 with Manager
# =============================================================================
# Different schedule series: distinct ICS UID, independent occurrence keys.

<urn:plan:monthly-1on1> a cco:ont00000974 ;
    rdfs:label "Monthly 1-on-1 with manager" ;
    actions:hasAlias "1on1" ;
    actions:hasUUID "bbbbbbbb-bbbb-4bbb-8bbb-bbbbbbbbbbbb" ;
    bfo:BFO_0000050 <urn:charter:work/clearhead> ;
    cco:ont00001942 <urn:action:1on1-2026-05-15> .

<urn:action:1on1-2026-05-15> a actions:Action ;
    cco:ont00001868 actions:NotStarted ;
    actions:hasScheduledDateTime "2026-05-15T14:00:00Z"^^xsd:dateTime ;
    actions:hasDueDateTime       "2026-05-15T15:00:00Z"^^xsd:dateTime ;
    actions:hasDurationMinutes 60 ;
    actions:hasExternalScheduleId   "1on1-monthly@work.example.com" ;
    actions:hasExternalOccurrenceKey "20260515T140000Z" .

# =============================================================================
# Ad-hoc Action (no plan, no external schedule)
# =============================================================================
# Directly in the charter via bfo:BFO_0000051; captured as a one-off work item.

<urn:action:ad-hoc-release-notes> a actions:Action ;
    rdfs:label "Draft v0.3 release notes" ;
    cco:ont00001868 actions:NotStarted ;
    actions:hasScheduledDateTime "2026-05-16T11:00:00Z"^^xsd:dateTime ;
    actions:hasDurationMinutes 45 .
