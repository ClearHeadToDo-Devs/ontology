@prefix actions: <https://clearhead.us/vocab/actions/v4#> .
@prefix cco: <https://www.commoncoreontologies.org/> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# Canonical Home-Life Domain Example (v4.3.0)
# =============================================================================
# Exercises:
# - Charter hierarchy via actions:hasSubCharter
# - Recurring plan with independent do/due recurrence rules
# - One-off plan with both scheduled and due dates
# - Sequential child plans under a parent plan
# =============================================================================

# Charter hierarchy
<urn:charter:home> a actions:Charter ;
    rdfs:label "Home" ;
    actions:hasSubCharter <urn:charter:home/maintenance> ;
    actions:hasSubCharter <urn:charter:home/health> .

<urn:charter:home/maintenance> a actions:Charter ;
    rdfs:label "Home Maintenance" .

<urn:charter:home/health> a actions:Charter ;
    rdfs:label "Household Health" .

# Plan 1: recurring trash cycle (Sunday do, Monday due)
<urn:plan:trash-cycle> a cco:ont00000974 ;
    rdfs:label "Take out trash" ;
    actions:hasAlias "trash" ;
    actions:hasUUID "11111111-1111-4111-8111-111111111111" ;
    actions:hasRecurrenceRule "FREQ=WEEKLY;BYDAY=SU" ;
    actions:hasDueRecurrenceRule "FREQ=WEEKLY;BYDAY=MO" ;
    bfo:BFO_0000050 <urn:charter:home/maintenance> ;
    cco:ont00001942 <urn:act:trash-2026-04-12> .

<urn:act:trash-2026-04-12> a actions:Action ;
    cco:ont00001868 actions:NotStarted ;
    actions:hasScheduledDateTime "2026-04-12T19:00:00Z"^^xsd:dateTime ;
    actions:hasDueDateTime "2026-04-13T07:00:00Z"^^xsd:dateTime ;
    actions:hasDurationMinutes 20 .

# Plan 2: one-off taxes task (both scheduled and due)
<urn:plan:file-taxes-2026> a cco:ont00000974 ;
    rdfs:label "File taxes" ;
    actions:hasAlias "taxes-2026" ;
    actions:hasUUID "22222222-2222-4222-8222-222222222222" ;
    bfo:BFO_0000050 <urn:charter:home/maintenance> ;
    cco:ont00001942 <urn:act:file-taxes-2026> .

<urn:act:file-taxes-2026> a actions:Action ;
    cco:ont00001868 actions:InProgress ;
    actions:hasScheduledDateTime "2026-04-14T16:00:00Z"^^xsd:dateTime ;
    actions:hasDueDateTime "2026-04-15T23:59:00Z"^^xsd:dateTime ;
    actions:hasDurationMinutes 90 .

# Plan 3: morning run with sequential children
<urn:plan:morning-run> a cco:ont00000974 ;
    rdfs:label "Morning run routine" ;
    actions:hasSequentialChildren true ;
    bfo:BFO_0000050 <urn:charter:home/health> ;
    bfo:BFO_0000051 <urn:plan:morning-run/lace-shoes> ;
    bfo:BFO_0000051 <urn:plan:morning-run/run-5k> .

<urn:plan:morning-run/lace-shoes> a cco:ont00000974 ;
    rdfs:label "Lace shoes" ;
    bfo:BFO_0000050 <urn:plan:morning-run> ;
    cco:ont00001942 <urn:act:lace-shoes-001> .

<urn:act:lace-shoes-001> a actions:Action ;
    cco:ont00001868 actions:Completed ;
    actions:hasScheduledDateTime "2026-04-12T06:25:00Z"^^xsd:dateTime ;
    actions:hasCompletedDateTime "2026-04-12T06:27:00Z"^^xsd:dateTime ;
    actions:hasDurationMinutes 2 .

<urn:plan:morning-run/run-5k> a cco:ont00000974 ;
    rdfs:label "Run 5K" ;
    cco:ont00001775 <urn:plan:morning-run/lace-shoes> ;
    bfo:BFO_0000050 <urn:plan:morning-run> ;
    cco:ont00001942 <urn:act:run-5k-001> .

<urn:act:run-5k-001> a actions:Action ;
    cco:ont00001868 actions:NotStarted ;
    actions:hasScheduledDateTime "2026-04-12T06:30:00Z"^^xsd:dateTime ;
    actions:hasDurationMinutes 35 .
